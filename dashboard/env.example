# ===========================================
# FiveM Logs Dashboard - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=fivem_logs

# JWT Secret (generate a strong random string - at least 32 characters)
# openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Bootstrap admin (created automatically when the users table is empty)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-this-password

# Set true only when the dashboard is served over HTTPS
COOKIE_SECURE=false

# Elasticsearch API (Backend)
NEXT_PUBLIC_API_URL=http://localhost:3000
